---
import Experience from "./Experience.astro";
import ProjectsGrid from "../shared/ProjectsGrid.astro";
import AboutMe from "../shared/AboutMe.astro";

const lang =
  Astro.request.headers.get("cookie")?.match(/preferredLang=([^;]+)/)?.[1] ||
  "es";
---

<section
  id="about"
  data-section="about"
  aria-label="About section"
  class="bg-[#161512] py-24 transition-colors duration-300"
>
  <AboutMe />
</section>

<section
  id="projects"
  data-section="projects"
  aria-label="Projects section"
  class="bg-[#161512]"
>
  {/* 2. Pasamos el lang como prop */}
  <ProjectsGrid lang={lang} />
</section>

<section
  id="experience"
  data-section="experience"
  aria-label="Experience section"
  class="section min-h-screen bg-[#161512] py-16 transition-colors duration-300"
>
  <Experience />
</section>

<style>
  section {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE y Edge */
  }

  section::-webkit-scrollbar {
    display: none; /* Chrome, Safari y Opera */
  }
</style>
